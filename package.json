{
  "name": "air-filter-shipment-system",
  "version": "1.0.0",
  "description": "Shipment management system for air filter deliveries",
  "main": "server/server.js",
  "scripts": {
    "dev:frontend": "vite",
    "dev:backend": "nodemon server/server.js",
    "start": "node server/server.js",
    "seed-fixtures": "sqlite3 database.db \".read fixtures/supplemental-fixtures.sql\"",
    "seed-properties": "node server/scripts/seed-properties.js",
    "test": "jest --testPathPattern=server/__tests__ --runInBand",
    "test:watch": "jest --testPathPattern=server/__tests__ --runInBand --watch"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/server/__tests__/**/*.test.js"
    ]
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "csv-parse": "^5.6.0",
    "express": "^5.2.1",
    "multer": "^2.2.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sonner": "^2.0.7"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "jest": "^29.7.0",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2",
    "vite": "^8.1.3"
  }
}
